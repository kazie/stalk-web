    "@types/jsdom": "^28.0.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-vue-devtools": "^8.1.2",
